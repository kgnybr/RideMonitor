void setup() {
  pinMode(buttonPin, INPUT_PULLUP);
  pinMode(ignitionPin, INPUT);
  attachInterrupt(digitalPinToInterrupt(ignitionPin), countPulse, RISING);
  for (int i = 0; i < ledCount; i++) {
    pinMode(ledPins[i], OUTPUT);
    digitalWrite(ledPins[i], LOW);
  }
  debouncer.attach(buttonPin);
  debouncer.interval(5);  
  Serial.begin(9600);
  if (!bmp.begin()) {
    Serial.println("BMP085 başlatılamadı, sensör bulunamadı");
    while (1)
      ;  
  }
  display.begin(SSD1306_SWITCHCAPVCC, 0x3C);  
  display.setTextColor(WHITE);               
  menuWelcome();
  delay(2000);
  menuAIO();
  delay(5000);
}

void loop() {
  unsigned long currentTime = millis();
  if (currentTime - previousTime >= 250) {
    
    unsigned long frequency = 4*pulseCount;
    rpm = (frequency * 60) / 2;
    pulseCount = 0;
    previousTime = currentTime;
  }
  rpmLed(rpm);
  debouncer.update();
  if (debouncer.fell()) {
    menuSayac++;
    if (menuSayac == 5) menuSayac = 0;
  }
  if (menuSayac == 0) {
    menuRPM();
  } else if (menuSayac == 1) {
    menuTemp();
  } else if (menuSayac == 2) {
    menuAltitude();
  } else if (menuSayac == 3) {
    menuPressure();
  } else if (menuSayac == 4) {
    menuVoltage();
  }
}


void menuWelcome() {
  display.clearDisplay();
  display.drawBitmap(0, 0, carLogo, SCREEN_WIDTH, SCREEN_HEIGHT, WHITE);
  display.display();
}
void menuTemp() {
  display.clearDisplay();
  display.drawBitmap(0, 0, tempLogo, SCREEN_WIDTH, SCREEN_HEIGHT, WHITE);
  display.setCursor(24, 8);
  display.setTextSize(2);
  display.print(bmp.readTemperature());
  display.print(" C");
  display.display();
}
void menuAltitude() {
  display.clearDisplay();
  display.drawBitmap(0, 0, altLogo, SCREEN_WIDTH, SCREEN_HEIGHT, WHITE);
  display.setCursor(24, 8);
  display.setTextSize(2);
  display.print(bmp.readAltitude());
  display.print(" m");
  display.display();
}
void menuPressure() {
  pressure_hPa = bmp.readPressure() / 100.0;
  display.clearDisplay();
  display.drawBitmap(0, 0, atmLogo, SCREEN_WIDTH, SCREEN_HEIGHT, WHITE);
  display.setCursor(30, 8);
  display.setTextSize(2);
  display.print(pressure_hPa);
  display.setTextSize(1);
  display.print(" hPa");
  display.display();
}
void menuRPM() {
  display.clearDisplay();
  display.drawBitmap(0, 0, rpmLogo, SCREEN_WIDTH, SCREEN_HEIGHT, WHITE);
  display.setCursor(40, 8);
  display.setTextSize(2);
  display.print(rpm);
  display.display();
}
void menuVoltage() {
  analogDeger = analogRead(voltagePin);
  akuGerilimi = analogDeger * voltage_carpan;
  display.clearDisplay();
  display.drawBitmap(0, 0, akuLogo, SCREEN_WIDTH, SCREEN_HEIGHT, WHITE);
  display.setCursor(45, 8);
  display.setTextSize(2);
  display.print(akuGerilimi, 1);
  display.print(" V");
  display.display();
}
void menuAIO() {
  analogDeger = analogRead(voltagePin);
  akuGerilimi = analogDeger * voltage_carpan;
  display.clearDisplay();
  display.setCursor(0, 0);
  display.setTextSize(1);
  display.print("Aku Voltaji: ");
  display.print(akuGerilimi, 1);
  display.print(" V");
  display.setCursor(0, 9);
  display.print("Sicaklik: ");
  display.print(bmp.readTemperature());
  display.print(" C");
  display.setCursor(0, 18);
  display.print("Rakim: ");
  display.print(bmp.readAltitude());
  display.print(" m");
  display.display();
}
void countPulse() {
  pulseCount++;
}
void rpmLed(int rpm) {
   for (int i = 0; i < ledCount; i++) {
    if (rpm > i * 1000) {
      digitalWrite(ledPins[i], HIGH); 
    } else {
      digitalWrite(ledPins[i], LOW); 
  }

}

